<Window x:Class="FcDriverFixer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Plug &amp; Pray"
        Width="460" Height="548"
        WindowStyle="None" ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
  </shell:WindowChrome.WindowChrome>

  <Border>
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
        <GradientStop Color="{StaticResource BgTopColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BgBottomColor}" Offset="1"/>
      </LinearGradientBrush>
    </Border.Background>

    <Grid Margin="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="36"/>
        <!-- title bar -->
        <RowDefinition Height="*"/>
        <!-- content block, vertically centred -->
        <RowDefinition Height="Auto"/>
        <!-- links -->
        <RowDefinition Height="Auto"/>
        <!-- footer -->
      </Grid.RowDefinitions>

      <!-- ================= Title bar ================= -->
      <Grid Grid.Row="0">
        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="&#x26A1;" FontSize="13" Foreground="{StaticResource Accent}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="Plug &amp; Pray" FontSize="12" FontWeight="SemiBold"
                     Foreground="{StaticResource TextMuted}" Margin="7,0,0,0"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button x:Name="MinBtn" Style="{StaticResource ChromeButton}" Content="&#xE921;"/>
          <Button x:Name="CloseBtn" Style="{StaticResource ChromeButton}" Content="&#xE8BB;"/>
        </StackPanel>
      </Grid>

      <!-- ============ Content block (centred as one group) ============ -->
      <StackPanel Grid.Row="1" VerticalAlignment="Center">

      <!-- ================= Hero status badge ================= -->
      <Grid Height="150">
        <!-- soft glow behind the ring -->
        <Ellipse x:Name="Glow" Width="150" Height="150" Opacity="0.16">
          <Ellipse.Fill>
            <RadialGradientBrush>
              <GradientStop x:Name="GlowStop" Color="#FF38BDF8" Offset="0"/>
              <GradientStop Color="#0038BDF8" Offset="1"/>
            </RadialGradientBrush>
          </Ellipse.Fill>
        </Ellipse>

        <Ellipse x:Name="Ring" Width="108" Height="108" StrokeThickness="3"
                 Stroke="{StaticResource Accent}" Fill="#FF141C2A"/>

        <TextBlock x:Name="Glyph" Text="&#x26A1;" FontSize="46"
                   Foreground="{StaticResource Accent}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Grid>

      <!-- ================= Headline + detail ================= -->
      <StackPanel Margin="34,18,34,0">
        <TextBlock x:Name="Headline" Text="Checking your board…"
                   FontSize="19" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
        <TextBlock x:Name="Detail" Text=""
                   FontSize="12.5" Foreground="{StaticResource TextMuted}"
                   TextWrapping="Wrap" TextAlignment="Center"
                   LineHeight="19" Margin="0,10,0,0"/>

        <!-- What the board reports it is running, when it will tell us. -->
        <Border x:Name="FirmwarePanel" Visibility="Collapsed"
                Margin="0,16,0,0" Padding="14,9" CornerRadius="8"
                Background="#FF141C29" BorderBrush="#FF243044" BorderThickness="1"
                HorizontalAlignment="Center">
          <TextBlock x:Name="FirmwareText" Text=""
                     FontSize="12" Foreground="#FF9FB0C7"
                     TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
      </StackPanel>

      <!-- ================= Progress ================= -->
      <StackPanel x:Name="ProgressPanel" Margin="34,22,34,0"
                  Visibility="Collapsed">
        <TextBlock x:Name="StepText" Text="" FontSize="11.5"
                   Foreground="{StaticResource Accent}" TextAlignment="Center"
                   TextWrapping="Wrap" Margin="0,0,0,9"/>
        <ProgressBar x:Name="Bar" Style="{StaticResource SlimBar}"
                     Minimum="0" Maximum="100" Value="0"/>
      </StackPanel>

      <!-- ================= Primary action ================= -->
      <Button x:Name="PrimaryBtn" Style="{StaticResource AccentButton}"
              Content="Please wait…" Margin="34,24,34,0" IsEnabled="False"/>

      </StackPanel>
      <!-- end content block -->

      <!-- ================= Secondary links ================= -->
      <Grid Grid.Row="2" Margin="30,10,30,0">
        <Button x:Name="UndoBtn" Style="{StaticResource LinkButton}"
                Content="Undo" HorizontalAlignment="Left" Visibility="Collapsed"/>
        <Button x:Name="RescanBtn" Style="{StaticResource LinkButton}"
                Content="Rescan" HorizontalAlignment="Right"/>
      </Grid>

      <!-- ================= Footer trust line ================= -->
      <TextBlock Grid.Row="3" Margin="0,14,0,16" TextAlignment="Center"
                 FontSize="10.5" Foreground="#FF55637A">
        Works offline · Only touches the bootloader · Fully reversible
      </TextBlock>
    </Grid>
  </Border>
</Window>
